# -----------------------------------------------------------------------------
# Choose exactly one provider/authentication configuration below.
# The model variables are public model IDs for OpenAI and deployment names for
# Azure OpenAI.
# -----------------------------------------------------------------------------

# A) Public OpenAI with an API key
LLM_PROVIDER=openai
LLM_AUTH_MODE=api_key
OPENAI_API_KEY=replace-me
# Optional for an OpenAI-compatible proxy. Usually leave unset.
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_JUDGE_MODEL=gpt-4.1-mini

# B) Azure OpenAI with an API key
# LLM_PROVIDER=azure
# LLM_AUTH_MODE=api_key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# Alternatively supply the full v1 URL:
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1/
# AZURE_OPENAI_API_KEY=replace-me
# OPENAI_MODEL=your-agent-deployment-name
# OPENAI_JUDGE_MODEL=your-judge-deployment-name

# C) Azure OpenAI with DefaultAzureCredential / Managed Identity
# LLM_PROVIDER=azure
# LLM_AUTH_MODE=managed_identity
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# OPENAI_MODEL=your-agent-deployment-name
# OPENAI_JUDGE_MODEL=your-judge-deployment-name
# Optional for a user-assigned managed identity:
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_OPENAI_SCOPE=https://ai.azure.com/.default

# HTTP resilience
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_READ_TIMEOUT_SECONDS=90
LLM_WRITE_TIMEOUT_SECONDS=30
LLM_POOL_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=2
LLM_LOG_LEVEL=INFO

# Application storage and cost estimates
SQLITE_DB_PATH=optimizer.sqlite3
ESTIMATED_INPUT_COST_PER_1M_TOKENS=0.15
ESTIMATED_OUTPUT_COST_PER_1M_TOKENS=0.60
