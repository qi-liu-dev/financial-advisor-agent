# =============================================================================
# LLM provider
# =============================================================================
# Public OpenAI: openai + api_key
# Azure OpenAI API key: azure + api_key
# Azure OpenAI Managed Identity: azure + managed_identity
LLM_PROVIDER=openai
LLM_AUTH_MODE=api_key

# Public OpenAI
OPENAI_API_KEY=replace-me
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_JUDGE_MODEL=gpt-4.1-mini

# Azure OpenAI (uncomment instead of the public OpenAI values above)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com/openai/v1/
# AZURE_OPENAI_API_KEY=replace-me
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
# AZURE_OPENAI_SCOPE=https://ai.azure.com/.default
# On Azure, OPENAI_MODEL and OPENAI_JUDGE_MODEL are deployment names.

# LLM HTTP resilience and metadata-only logging
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_READ_TIMEOUT_SECONDS=90
LLM_WRITE_TIMEOUT_SECONDS=30
LLM_POOL_TIMEOUT_SECONDS=10
LLM_MAX_RETRIES=2
LLM_LOG_LEVEL=INFO

# Optional policy: require a judge deployment different from the agent deployment.
REQUIRE_DISTINCT_JUDGE_MODEL=false
# Set true when an LLM configuration must be present for readiness to succeed.
REQUIRE_LLM_FOR_READINESS=false

# =============================================================================
# API and Angular/browser integration
# =============================================================================
API_PREFIX=/api/v1
CORS_ALLOWED_ORIGINS=http://localhost:4200
CORS_ALLOW_CREDENTIALS=false

# disabled: local development principal
# api_key: X-API-Key or Bearer token matched against API_KEYS_JSON
# azure_easy_auth: trust identity headers injected by Azure's authentication layer
AUTH_MODE=disabled
DEV_PRINCIPAL_ID=demo-advisor
DEV_PRINCIPAL_ROLES=admin,advisor

# Example for AUTH_MODE=api_key. Keep real credentials out of Git.
# API_KEYS_JSON={"replace-with-random-key":{"principal_id":"advisor-001","display_name":"Demo Advisor","roles":["advisor"]},"replace-with-admin-key":{"principal_id":"admin-001","roles":["admin"]}}

# Single-process/demo limiter. Use API Management or another shared limiter for
# a multi-replica production deployment.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# Storage, privacy, retention
# =============================================================================
SQLITE_DB_PATH=optimizer.sqlite3
DATABASE_BUSY_TIMEOUT_MS=30000
DATA_RETENTION_DAYS=90

# Optional Fernet key for JSON fields containing inputs, outputs, preferences,
# evaluations, job requests, and audit metadata. Existing plaintext rows remain
# readable and newly written rows are encrypted when this is set.
# Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DATA_ENCRYPTION_KEY=replace-with-generated-fernet-key

# Cost estimates used only for evaluation/optimisation comparisons.
ESTIMATED_INPUT_COST_PER_1M_TOKENS=0.15
ESTIMATED_OUTPUT_COST_PER_1M_TOKENS=0.60

# =============================================================================
# Asynchronous optimisation and selection policy
# =============================================================================
# The included worker is process-local and suitable for development/demo use.
OPTIMISATION_WORKER_COUNT=2
OPTIMISATION_DEFAULT_REPETITIONS=2
OPTIMISATION_MAX_REPETITIONS=5

# Candidate acceptance policy:
# quality >= baseline + minimum delta
# safety >= baseline - safety tolerance
# latency <= baseline * latency ratio
# cost <= baseline * cost ratio
OPTIMISATION_MINIMUM_QUALITY_DELTA=0.05
OPTIMISATION_SAFETY_TOLERANCE=0.0
OPTIMISATION_LATENCY_TOLERANCE_RATIO=1.20
OPTIMISATION_COST_TOLERANCE_RATIO=1.10
